#!/bin/sh

if [ -e $ATHENA_HOME_PATH/plugins/maxima ]; then
  ATHENA_MAXIMA_PATH="$ATHENA_HOME_PATH/plugins/maxima/lisp"
else
  ATHENA_MAXIMA_PATH="$ATHENA_PATH/plugins/maxima/lisp"
fi
export ATHENA_MAXIMA_PATH

case $1 in
  cygwin) exec maxima.bat -p "`echo $ATHENA_MAXIMA_PATH/texmacs-maxima.lisp|cygpath --windows -f -`";;
  *) exec maxima -u $1 -l $2 -p "$ATHENA_MAXIMA_PATH/texmacs-maxima.lisp";;
esac
